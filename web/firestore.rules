rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users can only read/write their OWN document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    // Admin can read/write EVERYTHING
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Orders: user can read own, create own
    match /orders/{orderId} {
      allow read: if request.auth.uid == resource.data.userId || isAdmin();
      allow create: if request.auth != null;
    }

    // Products: anyone can read, only admin writes
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bank accounts: only admin
    match /bankAccounts/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Dealers: anyone can read, only admin writes
    match /dealers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Dealer Applications: anyone can create, only admin can read/manage
    match /dealer_applications/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
