rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Product images: anyone can read, only admin can write
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Payment screenshots: users can upload, admin can read/manage
    match /payment-screenshots/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if isAdmin();
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
